[research]
description=Bulk RNA-Seq analysis. Measures average gene expression across a cell population.
name=index_align_bulk_rna_seq

[run]
command=docker run --rm 
script= /home/index_align.sh
image= repbioinfo/rnaseqstar_v2 

[directory]
name=workDir
description=working directory path
flag=io
mount=/workDir
#
[directory]
name=genome
description=genome directory path
flag=io
mount=/genome

[directory]
name=scratch
description=scratch directory path(Data)
flag=io
mount=/scratch
