[research]
description=A comprehensive toolkit for FASTA/FASTQ file manipulation, filtering, and statistics.
[run]
command=singularity exec --writable-tmpfs
script= seqkit
image= docker://quay.io/biocontainers/seqkit:2.8.1--h9ee0642_0
usage= <command> -M <length> <filein> -o <outdir>/<fileout>
#
[file]
name=filein
flag=cp
description=file to analize
#
[directory]
name=workDir
description= working directory
flag=io
mount=/workDir
#
[directory]
name=outDir
description= output directory
mount=/outDir
flag=out
#
[parameter]
name=fileout
description= output file name
#
[parameter]
name=command
values= seq, stats
description= SeqKit subcommands to run
#
[parameter]
name=length
description= maximum sequence length to keep (-M option)
#
#